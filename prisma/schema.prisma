// ── Trainer Vacancy (Gym Owner posts job openings) ──────────
enum VacancySalaryType {
  PER_MONTH
  PER_YEAR
}

enum TrainerVacancyStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

model TrainerVacancy {
  id                  String               @id @default(uuid())
  gymOwnerLeadId      String
  role                HireTrainerRole
  yearsOfExperience   Int?
  ptClientExperience  Int?
  description         String?              @db.Text
  specialization      String?
  certificate         String?
  isPTTrainer         Boolean              @default(false)
  howSoonCanJoin      String?
  gender              String?
  salaryMin           Decimal?             @db.Decimal(10, 2)
  salaryMax           Decimal?             @db.Decimal(10, 2)
