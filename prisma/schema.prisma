generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String          @id @default(uuid())
  email                   String          @unique
  password                String
  name                    String
  isActive                Boolean         @default(true)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  roleId                  String?
  ownedGym                Gym?            @relation("GymOwner")
  memberProfile           Member?
  refreshTokens           RefreshToken[]
  trainerProfile          Trainer?
  role                    Rolemaster?     @relation(fields: [roleId], references: [Id])
  memberInquiries         MemberInquiry[]
  createdDietTemplates    DietTemplate[]  @relation("DietTemplateCreator")
  assignedMemberDiets     MemberDiet[]    @relation("MemberDietAssigner")
  passwordResetHistory    PasswordResetHistory[]

  @@index([email])
  @@index([roleId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model GymSubscriptionPlan {
  id            String   @id @default(uuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  durationDays  Int
  features      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  priceCurrency String   @default("INR")
  gyms                Gym[]
  subscriptionHistory GymSubscriptionHistory[]
  gymInquiries        GymInquiry[]

  @@index([isActive])
  @@index([priceCurrency])
}

model Gym {
  id                 String               @id @default(uuid())
  name               String
  address            String?              // Legacy field - use address1, address2 instead
  address1           String?              // Primary address line
  address2           String?              // Secondary address line
  city               String?
  state              String?
  zipcode            String?              // Only numbers allowed (validated at API level)
  phone              String?              // Legacy field - use phoneNo instead
  mobileNo           String?              // Only numbers allowed (validated at API level)
  phoneNo            String?              // Only numbers allowed (validated at API level)
  email              String?              // Email with validation at API level
  gstRegNo           String?              // GST Registration Number
  website            String?
  memberSize         Int?                 // Expected number of members
  note               String?              // Terms and Conditions shown on receipts
  logo               String?              // Legacy field - use gymLogo instead
  gymLogo            String?              // Path to gym logo image
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  ownerId            String?              @unique
  subscriptionPlanId String?
  ownerPassword      String?              // Plain text password for admin display hint
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  dietPlans          DietPlan[]
  exercisePlans      ExercisePlan[]
  owner              User?                @relation("GymOwner", fields: [ownerId], references: [id])
  subscriptionPlan   GymSubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  members            Member[]
  trainers           Trainer[]
  expenseGroups      ExpenseGroupMaster[]
  expenses           ExpenseMaster[]
  designations       DesignationMaster[]
  bodyParts          BodyPartMaster[]
  workoutExercises   WorkoutExerciseMaster[]
  memberInquiries    MemberInquiry[]
  coursePackages     CoursePackage[]
  dietTemplates      DietTemplate[]
  memberDiets        MemberDiet[]
  salarySettlements  TrainerSalarySettlement[]
  subscriptionHistory GymSubscriptionHistory[]

  @@index([ownerId])
  @@index([city])
  @@index([state])
  @@index([zipcode])
  @@index([gstRegNo])
}

model Trainer {
  id              String                    @id @default(uuid())
  name            String?                   // Trainer's full name (synced from User table)
  email           String?                   @unique // Trainer's email (synced from User table)
  password        String?                   // Hashed password for easy management
  specialization  String?
  experience      Int?
  phone           String?
  gender          String?                   // Male, Female, Other
  dateOfBirth     DateTime?                 // Trainer's date of birth
  joiningDate     DateTime?                 // Date when trainer joined the gym
  salary          Decimal?                  @db.Decimal(10, 2) // Monthly salary
  trainerPhoto    String?                   // Path to trainer's passport size photo
  idProofType     String?                   // Type of ID proof (Aadhar, PAN, etc.)
  idProofDocument String?                   // Path to uploaded ID document
  isActive        Boolean                   @default(true)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  createdBy       String?
  updatedBy       String?
  userId          String                    @unique
  gymId           String
  members         MemberTrainerAssignment[]
  ptMembers       PTMember[]
  salarySettlements TrainerSalarySettlement[]
  gym             Gym                       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@index([isActive])
  @@index([email])
}

model Member {
  id                  String                     @id @default(uuid())
  name                String?                    // Member's full name (synced from User table)
  email               String?                    @unique // Member's email (synced from User table)
  password            String?                    // Hashed password for easy management
  memberId            String?                    // Auto-generated member ID (e.g., 1413)
  phone               String?
  altContactNo        String?                    // Alternate contact number
  dateOfBirth         DateTime?
  gender              String?
  address             String?
  occupation          String?                    // Member's occupation
  maritalStatus       String?                    // Marital status
  bloodGroup          String?                    // Blood group
  anniversaryDate     DateTime?                  // Anniversary date
  emergencyContact    String?
  healthNotes         String?
  idProofType         String?                    // Type of ID proof (Aadhar, PAN, etc.)
  idProofDocument     String?                    // Path to uploaded ID document
  memberPhoto         String?                    // Path to member photo
  smsFacility         Boolean                    @default(true)  // SMS facility preference
  isActive            Boolean                    @default(true)  // For soft delete
  memberType          MemberType                 @default(REGULAR)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  createdBy           String?
  updatedBy           String?
  userId              String                     @unique
  gymId               String
  membershipStart     DateTime                   @default(now())
  membershipEnd       DateTime
  coursePackageId     String?                    // Reference to course package
  packageFees         Decimal?                   @db.Decimal(10, 2) // Original package fees
  maxDiscount         Decimal?                   @db.Decimal(10, 2) // Maximum allowed discount
  afterDiscount       Decimal?                   @db.Decimal(10, 2) // Amount after applying max discount
  extraDiscount       Decimal?                   @db.Decimal(10, 2) // Additional extra discount
  finalFees           Decimal?                   @db.Decimal(10, 2) // Final fees after all discounts
  membershipStatus    SubscriptionStatus         @default(ACTIVE)
  
  // PT Addon Fields - For combined Regular + PT memberships
  hasPTAddon          Boolean                    @default(false)  // Whether member has active PT addon
  ptPackageName       String?                    // PT package name
  ptPackageFees       Decimal?                   @db.Decimal(10, 2) // Original PT package fees
  ptMaxDiscount       Decimal?                   @db.Decimal(10, 2) // PT max discount allowed
  ptAfterDiscount     Decimal?                   @db.Decimal(10, 2) // PT amount after max discount
  ptExtraDiscount     Decimal?                   @db.Decimal(10, 2) // PT extra discount
  ptFinalFees         Decimal?                   @db.Decimal(10, 2) // PT final fees after all discounts
  
  gym                 Gym                        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietAssignments     MemberDietAssignment[]
  exerciseAssignments MemberExerciseAssignment[]
  trainerAssignments  MemberTrainerAssignment[]
  ptMember            PTMember?
  memberDietPlans     MemberDietPlan[]
  balancePayments     MemberBalancePayment[]     // Balance payment records
  membershipRenewals  MembershipRenewal[]        // Membership renewal history
  ptSessionCredits    PTSessionCredit[]          // PT session credits for carry forward
  assignedDiets       MemberDiet[]               @relation("MemberDietAssignments") // Diet assignments

  @@index([gymId])
  @@index([membershipStatus])
  @@index([memberType])
  @@index([memberId])
  @@index([isActive])
  @@index([hasPTAddon])
  @@index([email])
}

// Member Balance Payment - tracks partial payments toward final fees
model MemberBalancePayment {
  id              String     @id @default(uuid())
  receiptNo       String     // Auto-generated receipt number (e.g., RCP-001)
  memberId        String     // Reference to Member
  paymentFor      PaymentFor @default(REGULAR)  // REGULAR or PT - which fees this payment is for
  paymentDate     DateTime   @default(now())
  contactNo       String?    // Member contact (from member or override)
  paidFees        Decimal    @db.Decimal(10, 2) // Amount paid in this transaction
  payMode         String     // CASH, CARD, UPI, BANK_TRANSFER, CHEQUE, etc.
  nextPaymentDate DateTime?  // Optional next payment reminder date
  notes           String?    // Optional notes/remarks
  isActive        Boolean    @default(true)
  gymId           String     // Reference to Gym for ownership
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdBy       String?
  updatedBy       String?
  member          Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([gymId])
  @@index([receiptNo])
  @@index([paymentDate])
  @@index([paymentFor])
  @@map("memberbalancepayment")
}

model PTMember {
  id              String       @id @default(uuid())
  memberId        String       @unique
  trainerId       String
  packageName     String
  sessionsTotal   Int          @default(0)
  sessionsUsed    Int          @default(0)
  sessionDuration Int          @default(60)
  startDate       DateTime     @default(now())
  endDate         DateTime?
  goals           String?
  notes           String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String?
  updatedBy       String?
  gymId           String
  member          Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer         Trainer      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  supplements     Supplement[]

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
}

// PT Session Credit - For carrying forward unused sessions when PT is removed
model PTSessionCredit {
  id              String    @id @default(uuid())
  memberId        String    // Reference to Member
  sessionCredits  Int       // Number of sessions credited
  originalPackage String    // Original PT package name
  creditDate      DateTime  @default(now()) // When credit was created
  expiryDate      DateTime  // When credit expires (typically 6 months)
  usedCredits     Int       @default(0) // Credits already used
  reason          String?   // Why sessions were credited (e.g., "PT membership removed")
  notes           String?   // Optional notes
  isActive        Boolean   @default(true)
  gymId           String    // Reference to Gym
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?
  member          Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([gymId])
  @@index([expiryDate])
  @@index([isActive])
  @@map("ptsessioncredit")
}

model Supplement {
  id          String    @id @default(uuid())
  ptMemberId  String
  name        String
  dosage      String?
  frequency   String?
  timing      String?
  notes       String?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  gymId       String
  ptMember    PTMember  @relation(fields: [ptMemberId], references: [id], onDelete: Cascade)

  @@index([ptMemberId])
  @@index([gymId])
}

model MemberDietPlan {
  id          String    @id @default(uuid())
  memberId    String
  planName    String
  description String?
  calories    Int?
  meals       Json
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  gymId       String
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([gymId])
}

model Inquiry {
  id          String        @id @default(uuid())
  name        String
  email       String?
  phone       String
  source      InquirySource @default(WALK_IN)
  interest    String?
  notes       String?
  status      InquiryStatus @default(NEW)
  followUpDate DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String?
  updatedBy   String?
  gymId       String

  @@index([gymId])
  @@index([status])
}

model MemberInquiry {
  id            String    @id @default(uuid())
  fullName      String
  contactNo     String
  inquiryDate   DateTime  @default(now())
  dob           DateTime?
  followUp      Boolean   @default(false)
  followUpDate  DateTime?
  gender        String?   // Male/Female/Other
  address       String?
  heardAbout    String?
  userId        String
  comments      String?
  memberPhoto   String?
  height        Decimal?  @db.Decimal(5, 2)
  weight        Decimal?  @db.Decimal(5, 2)
  referenceName String?
  gymId         String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?
  updatedBy     String?
  gym           Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberinquiry")
  @@index([gymId])
  @@index([userId])
  @@index([contactNo])
  @@index([inquiryDate])
  @@index([followUp])
  @@index([isActive])
}

model DietPlan {
  id          String                 @id @default(uuid())
  name        String
  description String?
  calories    Int?
  meals       Json
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  gymId       String
  gym         Gym                    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  assignments MemberDietAssignment[]

  @@index([gymId])
}

model ExercisePlan {
  id          String                     @id @default(uuid())
  name        String
  description String?
  type        String?
  exercises   Json
  isActive    Boolean                    @default(true)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  gymId       String
  gym         Gym                        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  assignments MemberExerciseAssignment[]

  @@index([gymId])
}

model MemberTrainerAssignment {
  id         String   @id @default(uuid())
  memberId   String
  trainerId  String
  assignedAt DateTime @default(now())
  isActive   Boolean  @default(true)
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer    Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([memberId, trainerId])
  @@index([memberId])
  @@index([trainerId])
}

model MemberDietAssignment {
  id         String    @id @default(uuid())
  memberId   String
  dietPlanId String
  assignedAt DateTime  @default(now())
  startDate  DateTime  @default(now())
  endDate    DateTime?
  isActive   Boolean   @default(true)
  dietPlan   DietPlan  @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  member     Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([dietPlanId])
}

model MemberExerciseAssignment {
  id             String       @id @default(uuid())
  memberId       String
  exercisePlanId String
  assignedAt     DateTime     @default(now())
  dayOfWeek      Int?
  startDate      DateTime     @default(now())
  endDate        DateTime?
  isActive       Boolean      @default(true)
  exercisePlan   ExercisePlan @relation(fields: [exercisePlanId], references: [id], onDelete: Cascade)
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([exercisePlanId])
}

model Rolemaster {
  Id       String @id @default(uuid()) @map("Id")
  rolename String @map("rolename")
  users    User[]

  @@map("Rolemaster")
}

model OccupationMaster {
  id             String   @id @default(uuid())
  occupationName String   @unique
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?

  @@map("occupationmaster")
  @@index([isActive])
  @@index([occupationName])
}

model EnquiryTypeMaster {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  gymInquiries GymInquiry[]

  @@map("enquirytypemaster")
  @@index([isActive])
  @@index([name])
}

model PaymentTypeMaster {
  id              String   @id @default(uuid())
  paymentTypeName String   @unique
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?

  @@map("paymenttypemaster")
  @@index([isActive])
  @@index([paymentTypeName])
}

model ExpenseGroupMaster {
  id               String          @id @default(uuid())
  expenseGroupName String
  gymId            String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  gym              Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  expenses         ExpenseMaster[]

  @@unique([expenseGroupName, gymId])
  @@map("expensegroupmaster")
  @@index([gymId])
  @@index([expenseGroupName])
}

model ExpenseMaster {
  id              String           @id @default(uuid())
  expenseDate     DateTime         @default(now())
  name            String
  expenseGroupId  String
  description     String?
  paymentMode     PaymentMode
  amount          Decimal          @db.Decimal(10, 2)
  attachments     String[]         @default([])
  createdBy       String
  gymId           String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  expenseGroup    ExpenseGroupMaster @relation(fields: [expenseGroupId], references: [id], onDelete: Restrict)
  gym             Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@map("expensemaster")
  @@index([gymId])
  @@index([expenseGroupId])
  @@index([expenseDate])
  @@index([isActive])
  @@index([createdBy])
}

model DesignationMaster {
  id              String   @id @default(uuid())
  designationName String
  gymId           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  gym             Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([designationName, gymId])
  @@map("designationmaster")
  @@index([gymId])
  @@index([designationName])
}

model BodyPartMaster {
  id           String                  @id @default(uuid())
  bodyPartName String
  description  String?
  isActive     Boolean                 @default(true)
  gymId        String
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  gym          Gym                     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  exercises    WorkoutExerciseMaster[]

  @@unique([bodyPartName, gymId])
  @@map("bodypartmaster")
  @@index([gymId])
  @@index([bodyPartName])
  @@index([isActive])
}

model WorkoutExerciseMaster {
  id           String          @id @default(uuid())
  exerciseName String
  shortCode    String?         @db.VarChar(20)
  description  String?
  isActive     Boolean         @default(true)
  gymId        String
  bodyPartId   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  gym          Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  bodyPart     BodyPartMaster? @relation(fields: [bodyPartId], references: [id], onDelete: SetNull)

  @@unique([exerciseName, gymId])
  @@map("workoutexercisemaster")
  @@index([gymId])
  @@index([exerciseName])
  @@index([shortCode])
  @@index([isActive])
  @@index([bodyPartId])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MemberType {
  REGULAR      // Regular membership only
  PT           // PT membership only (legacy support)
  REGULAR_PT   // Combined: Regular + PT membership
}

// Payment type - distinguishes between Regular and PT fee payments
enum PaymentFor {
  REGULAR   // Payment for regular membership fees
  PT        // Payment for PT membership fees
}

enum InquirySource {
  WALK_IN
  PHONE
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  OTHER
}

enum InquiryStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
  FOLLOW_UP
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
}

enum CoursePackageType {
  REGULAR   // Regular gym membership packages
  PT        // Personal Training packages
}

model CoursePackage {
  id                 String            @id @default(uuid())
  packageName        String
  description        String?
  fees               Decimal           @db.Decimal(10, 2)
  maxDiscount        Decimal?          @db.Decimal(10, 2)
  discountType       DiscountType      @default(PERCENTAGE)
  coursePackageType  CoursePackageType @default(REGULAR)
  Months             Int               @default(1) @map("Months")
  isActive           Boolean           @default(true)
  gymId              String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdBy          String?
  updatedBy          String?
  gym                Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([packageName, gymId])
  @@map("coursepackage")
  @@index([gymId])
  @@index([packageName])
  @@index([isActive])
  @@index([coursePackageType])
}

// Membership Renewal - Every renewal creates a NEW ROW for historical tracking
model MembershipRenewal {
  id                      String    @id @default(uuid())
  renewalNumber           String    // Auto-generated renewal number (e.g., REN-001)
  memberId                String    // Reference to Member
  gymId                   String    // Reference to Gym for ownership
  
  // Previous membership dates (before renewal)
  previousMembershipStart DateTime
  previousMembershipEnd   DateTime
  
  // New membership dates (after renewal)  
  newMembershipStart      DateTime
  newMembershipEnd        DateTime
  
  // Renewal details
  renewalDate             DateTime  @default(now()) // When the renewal was processed
  renewalType             RenewalType @default(STANDARD) // Type of renewal
  
  // Package and fees
  coursePackageId         String?   // Course package used for renewal
  packageFees             Decimal?  @db.Decimal(10, 2)
  maxDiscount             Decimal?  @db.Decimal(10, 2)
  afterDiscount           Decimal?  @db.Decimal(10, 2)
  extraDiscount           Decimal?  @db.Decimal(10, 2)
  finalFees               Decimal?  @db.Decimal(10, 2)
  
  // Payment info
  paymentStatus           PaymentStatus @default(PENDING)
  paymentMode             String?   // CASH, CARD, UPI, BANK_TRANSFER, etc.
  paidAmount              Decimal?  @db.Decimal(10, 2)
  pendingAmount           Decimal?  @db.Decimal(10, 2)
  
  notes                   String?
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  createdBy               String?
  updatedBy               String?
  
  member                  Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("membershiprenewal")
  @@index([memberId])
  @@index([gymId])
  @@index([renewalNumber])
  @@index([renewalDate])
  @@index([paymentStatus])
}

enum RenewalType {
  STANDARD      // Regular renewal
  EARLY         // Renewed before expiry
  LATE          // Renewed after expiry (lapsed member returning)
  UPGRADE       // Upgraded to a different package
  DOWNGRADE     // Downgraded to a different package
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIAL
}

enum PaymentMode {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
  NET_BANKING
  OTHER
}

enum GymSubscriptionRenewalType {
  NEW
  RENEWAL
  UPGRADE
  DOWNGRADE
}

model GymSubscriptionHistory {
  id                      String                      @id @default(uuid())
  subscriptionNumber      String                      // Auto-generated: GSUB-00001
  gymId                   String
  subscriptionPlanId      String
  subscriptionStart       DateTime
  subscriptionEnd         DateTime
  renewalDate             DateTime                    @default(now())
  previousPlanId          String?
  previousPlanName        String?
  previousSubscriptionEnd DateTime?
  renewalType             GymSubscriptionRenewalType  @default(NEW)
  planAmount              Decimal?                    @db.Decimal(10, 2)
  extraDiscount           Decimal?                    @db.Decimal(10, 2)
  amount                  Decimal                     @db.Decimal(10, 2)
  paymentMode             String?
  paymentStatus           PaymentStatus               @default(PAID)
  paidAmount              Decimal?                    @db.Decimal(10, 2)
  pendingAmount           Decimal?                    @db.Decimal(10, 2)
  isActive                Boolean                     @default(true)
  notes                   String?
  createdBy               String?
  updatedBy               String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  gym                     Gym                         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  subscriptionPlan        GymSubscriptionPlan         @relation(fields: [subscriptionPlanId], references: [id])

  @@index([gymId])
  @@index([subscriptionPlanId])
  @@index([isActive])
  @@index([subscriptionNumber])
  @@index([renewalDate])
  @@index([paymentStatus])
  @@map("gymsubscriptionhistory")
}
// ============================================
// Diet Template & Member Diet Models
// ============================================

// Diet Template - Reusable diet plans created by gym owners
model DietTemplate {
  id          String     @id @default(uuid())
  name        String
  description String?
  gymId       String     // Reference to Gym for ownership
  createdBy   String     // userId (UUID) who created this template
  isActive    Boolean    @default(true)
  meals       DietMeal[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  gym         Gym        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  creator     User       @relation("DietTemplateCreator", fields: [createdBy], references: [id])
  memberDiets MemberDiet[]

  @@map("diettemplate")
  @@index([gymId])
  @@index([createdBy])
  @@index([isActive])
}

// Diet Meal - Individual meals within a diet template (6 meals per day)
model DietMeal {
  id             String       @id @default(uuid())
  dietTemplateId String
  mealNo         Int          // 1 to 6 (Meal 1, Meal 2, etc.)
  title          String       // e.g., "Breakfast", "Mid-Morning Snack", "Lunch", etc.
  description    String       // What to eat
  time           String       // e.g., "07:30 AM", "10:00 AM", etc.
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  dietTemplate   DietTemplate @relation(fields: [dietTemplateId], references: [id], onDelete: Cascade)

  @@unique([dietTemplateId, mealNo])
  @@map("dietmeal")
  @@index([dietTemplateId])
}

// Member Diet - Diet assignment to a member
model MemberDiet {
  id             String           @id @default(uuid())
  memberId       String           // Reference to Member
  dietTemplateId String           // Reference to original DietTemplate
  gymId          String           // Reference to Gym for ownership
  startDate      DateTime
  endDate        DateTime?
  assignedBy     String           // userId (UUID) who assigned this diet
  isActive       Boolean          @default(true)
  notes          String?          // Optional notes about the diet assignment

  meals          MemberDietMeal[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  member         Member           @relation("MemberDietAssignments", fields: [memberId], references: [id], onDelete: Cascade)
  dietTemplate   DietTemplate     @relation(fields: [dietTemplateId], references: [id])
  gym            Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  assigner       User             @relation("MemberDietAssigner", fields: [assignedBy], references: [id])

  @@map("memberdiet")
  @@index([memberId])
  @@index([gymId])
  @@index([dietTemplateId])
  @@index([assignedBy])
  @@index([isActive])
  @@index([startDate])
}

// Member Diet Meal - Copied meals from template (can be customized per member)
model MemberDietMeal {
  id           String     @id @default(uuid())
  memberDietId String
  mealNo       Int        // 1 to 6
  title        String     // e.g., "Breakfast"
  description  String     // What to eat (can be customized)
  time         String     // e.g., "07:30 AM"
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberDiet   MemberDiet @relation(fields: [memberDietId], references: [id], onDelete: Cascade)

  @@unique([memberDietId, mealNo])
  @@map("memberdietmeal")
  @@index([memberDietId])
}

// ============================================
// Trainer Salary Settlement
// ============================================

// Incentive type for trainer salary
enum IncentiveType {
  PT               // Personal Training
  PROTEIN          // Protein/Supplement sales
  MEMBER_REFERENCE // Member referral bonus
  OTHERS           // Other incentives
}

// Trainer Salary Settlement - Monthly salary records
model TrainerSalarySettlement {
  id                  String        @id @default(uuid())
  trainerId           String        // Reference to Trainer
  trainerName         String        // Denormalized for reporting
  mobileNumber        String?       // Trainer's mobile number
  joiningDate         DateTime?     // Trainer's joining date
  monthlySalary       Decimal       @db.Decimal(10, 2) // Base monthly salary
  salaryMonth         String        // YYYY-MM format (e.g., "2025-01")
  salarySentDate      DateTime?     // Date when salary was settled
  totalDaysInMonth    Int           // Total days in the salary month
  presentDays         Int           // Days present
  absentDays          Int           // Days absent (totalDaysInMonth - presentDays)
  discountDays        Int           @default(0) // Days to discount from absent days
  payableDays         Int           // presentDays + discountDays
  calculatedSalary    Decimal       @db.Decimal(10, 2) // (monthlySalary / totalDaysInMonth) * payableDays
  incentiveAmount     Decimal       @default(0) @db.Decimal(10, 2) // Incentive amount
  incentiveType       IncentiveType? // Type of incentive
  paymentMode         PaymentMode   // CASH, UPI, BANK_TRANSFER, CARD, etc.
  finalPayableAmount  Decimal       @db.Decimal(10, 2) // calculatedSalary + incentiveAmount
  remarks             String?       // Additional notes

  // Audit fields
  gymId               String        // Reference to Gym
  createdBy           String        // Gym Owner who created this record
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  trainer             Trainer       @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  gym                 Gym           @relation(fields: [gymId], references: [id], onDelete: Cascade)

  // Unique constraint: One settlement per trainer per month per gym
  @@unique([trainerId, salaryMonth, gymId])
  @@map("trainersalarysettlement")
  @@index([gymId])
  @@index([trainerId])
  @@index([salaryMonth])
  @@index([createdAt])
  @@index([paymentMode])
}

model GymInquiry {
  id                  String               @id @default(uuid())
  gymName             String
  address1            String?
  address2            String?
  state               String?
  city                String?
  mobileNo            String
  email               String?
  subscriptionPlanId  String
  note                String?
  sellerName          String?
  sellerMobileNo      String?
  nextFollowupDate    DateTime?
  memberSize          Int?
  enquiryTypeId       String?
  isActive            Boolean              @default(true)
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  subscriptionPlan    GymSubscriptionPlan  @relation(fields: [subscriptionPlanId], references: [id])
  enquiryType         EnquiryTypeMaster?   @relation(fields: [enquiryTypeId], references: [id])
  followups           GymInquiryFollowup[]

  @@map("gyminquiry")
  @@index([isActive])
  @@index([subscriptionPlanId])
  @@index([nextFollowupDate])
  @@index([enquiryTypeId])
}

model GymInquiryFollowup {
  id            String      @id @default(uuid())
  gymInquiryId  String
  followupDate  DateTime    @default(now())
  note          String?
  createdBy     String?
  createdAt     DateTime    @default(now())

  gymInquiry    GymInquiry  @relation(fields: [gymInquiryId], references: [id], onDelete: Cascade)

  @@map("gyminquiryfollowup")
  @@index([gymInquiryId])
  @@index([followupDate])
}

// ============================================
// Password Reset History - Tracks all password resets across roles
// Admin can track which roles reset passwords, how many times, and when
// ============================================
model PasswordResetHistory {
  id              String    @id @default(uuid())
  userId          String    // Reference to User table
  email           String?   // Email of the user at the time of reset
  roleId          String?   // Role ID at the time of reset
  roleName        String?   // Role name at the time of reset (denormalized for reporting)
  resetBy         String?   // User ID of who performed the reset (admin/gym-owner/self)
  resetByEmail    String?   // Email of who performed the reset
  resetMethod     String    @default("MANUAL") // MANUAL, SELF, ADMIN_RESET, OWNER_RESET
  targetTable     String?   // Which table was updated: USER, TRAINER, MEMBER
  gymId           String?   // Gym ID (for gym-specific tracking)
  ipAddress       String?   // IP address of the requester
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passwordresethistory")
  @@index([userId])
  @@index([email])
  @@index([roleId])
  @@index([roleName])
  @@index([gymId])
  @@index([createdAt])
}