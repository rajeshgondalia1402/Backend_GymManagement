// ============================================
// Biometric Attendance System
// ============================================

// Finger positions for biometric enrollment
enum FingerPosition {
  RIGHT_THUMB
  RIGHT_INDEX
  RIGHT_MIDDLE
  RIGHT_RING
  RIGHT_LITTLE
  LEFT_THUMB
  LEFT_INDEX
  LEFT_MIDDLE
  LEFT_RING
  LEFT_LITTLE
}

// Attendance status
enum AttendanceStatus {
  CHECKED_IN // Member checked in, hasn't checked out
  CHECKED_OUT // Member checked out
  ABSENT // Marked absent (for reporting)
}

// How the attendance was verified
enum VerificationMethod {
  FINGERPRINT // Biometric fingerprint
  MANUAL // Manual entry by gym owner
  CARD // RFID card (future)
  FACE // Face recognition (future)
  QR_CODE // QR code scan (future)
}

// Type of biometric device
enum DeviceType {
  FINGERPRINT // USB fingerprint scanner
  FINGERPRINT_DOOR // All-in-one fingerprint + door controller
  FACE // Face recognition (future)
  IRIS // Iris scanner (future)
}

// Door lock integration type
enum DoorLockType {
  NONE // No door lock (attendance only)
  USB_RELAY // USB relay module for door control
  SMART_LOCK_API // Smart lock with HTTP API
  ESP32_HTTP // ESP32/Arduino with HTTP endpoint
  ZKTECO_DEVICE // ZKTeco all-in-one device
}

// Biometric Device - Scanner/Device Registration
model BiometricDevice {
  id    String @id @default(uuid())
  gymId String

  // Device Info
  deviceName   String // "Front Desk Scanner", "Main Entrance"
  deviceSerial String // Hardware serial number
  deviceModel  String // "SecuGen Hamster Pro 20", "ZKTeco K40"
  deviceType   DeviceType @default(FINGERPRINT)

  // WebUSB Info (for USB scanners)
  vendorId  Int? // USB Vendor ID (e.g., 0x1162 for SecuGen)
  productId Int? // USB Product ID

  // Network Info (for networked devices like ZKTeco)
  ipAddress String?
  port      Int?

  // Door Lock Integration
  doorLockType   DoorLockType @default(NONE)
  doorLockConfig Json? // Door lock configuration (relay pin, API URL, etc.)

  // Connection Status
  lastSeenAt DateTime?
  isOnline   Boolean   @default(false)

  // Location
  location String? // "Main Entrance", "Back Door"

  // Status
  isActive     Boolean  @default(true)
  registeredAt DateTime @default(now())
  registeredBy String // User ID who registered the device
  updatedAt    DateTime @updatedAt

  // Relations
  gym         Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@unique([deviceSerial])
  @@unique([gymId, deviceName])
  @@index([gymId])
  @@index([isActive])
  @@index([deviceType])
  @@map("biometric_device")
}

// Member Biometric - Fingerprint Templates
model MemberBiometric {
  id       String @id @default(uuid())
  memberId String @unique // One biometric record per member
  gymId    String // For gym-scoped queries

  // Fingerprint Templates (Encrypted binary data)
  // Store up to 2 fingers for redundancy
  fingerTemplate1 Bytes? // Primary finger template (encrypted)
  fingerTemplate2 Bytes? // Backup finger template (encrypted)
  fingerPosition1 FingerPosition? // Which finger (e.g., RIGHT_THUMB)
  fingerPosition2 FingerPosition?

  // Template Metadata
  templateFormat  String @default("ISO_19794_2") // ISO standard format
  templateVersion String @default("1.0")
  quality1        Int? // Quality score 0-100 for finger 1
  quality2        Int? // Quality score 0-100 for finger 2

  // Enrollment Info
  enrolledAt    DateTime @default(now())
  enrolledBy    String? // User ID who enrolled the member
  lastUpdatedAt DateTime @updatedAt
  deviceId      String? // Device used for enrollment

  // Status
  isActive       Boolean   @default(true)
  failedAttempts Int       @default(0) // Track consecutive failed verifications
  lastFailedAt   DateTime?

  // Relations
  member         Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  gym            Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  enrolledByUser User?  @relation(fields: [enrolledBy], references: [id])

  @@index([gymId])
  @@index([memberId])
  @@index([isActive])
  @@map("member_biometric")
}

// Attendance - Daily attendance records
model Attendance {
  id       String @id @default(uuid())
  memberId String
  gymId    String

  // Date & Time
  attendanceDate DateTime  @db.Date // Just the date portion (unique per member)
  checkInTime    DateTime // Full timestamp for check-in
  checkOutTime   DateTime? // Optional check-out timestamp

  // Duration (auto-calculated on check-out)
  durationMinutes Int? // Time spent in gym

  // Verification Details
  verificationMethod VerificationMethod
  verificationScore  Int? // Match score (0-100) for biometric
  deviceId           String? // Scanner device ID

  // Status
  status AttendanceStatus @default(CHECKED_IN)

  // Manual Override (for corrections)
  isManualEntry     Boolean @default(false)
  manualEntryBy     String? // User ID if manual entry
  manualEntryReason String?

  // Door Access
  doorUnlocked   Boolean   @default(false) // Whether door was unlocked
  doorUnlockTime DateTime?

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  member Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  gym    Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  device BiometricDevice? @relation(fields: [deviceId], references: [id])

  // Constraints: One attendance per member per day
  @@unique([memberId, attendanceDate])
  @@index([gymId])
  @@index([memberId])
  @@index([attendanceDate])
  @@index([gymId, attendanceDate]) // Composite for daily reports
  @@index([status])
  @@map("attendance")
}

// ============================================================
// HIRE TRAINER — Public marketplace for trainer applications
// ============================================================

enum HireTrainerRole {
  FIRST_HALF
  SECOND_HALF
  FULL_TIME
}

enum HireTrainerStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model HireTrainer {
  id                    String            @id @default(uuid())
  email                 String            @unique
  mobile                String
  fullName              String?
  address               String?
  whatsappNumber        String?
  country               String            @default("India")
  state                 String?
  city                  String?
  role                  HireTrainerRole?
  totalYearsExperience  Int?
  ptExperienceYears     Int?
  ptExperienceMonths    Int?
  currentSalary         Decimal?          @db.Decimal(10, 2)
  expectedSalary        Decimal?          @db.Decimal(10, 2)
  howSoonCanJoin        String?
  specialization        String?
  currentGymName        String?
  reasonForLeaving      String?
  numberOfGymsChanged   Int?
  gender                String?
  maritalStatus         String?
  status                HireTrainerStatus @default(DRAFT)
  currentStep           Int               @default(1)
  isSubmitted           Boolean           @default(false)
  submittedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  documents HireTrainerDocument[]

  @@index([status])
  @@index([city])
  @@index([role])
  @@index([specialization])
  @@map("hire_trainer")
}

model HireTrainerVerification {
  id            String    @id @default(uuid())
  email         String    @unique
  mobile        String?
  otpCode       String
  otpExpiresAt  DateTime
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@map("hire_trainer_verification")
}

model HireTrainerDocument {
  id             String      @id @default(uuid())
  hireTrainerId  String
  fileName       String
  fileUrl        String
  fileType       String
  fileSize       Int
  createdAt      DateTime    @default(now())

  hireTrainer HireTrainer @relation(fields: [hireTrainerId], references: [id], onDelete: Cascade)

  @@index([hireTrainerId])
  @@map("hire_trainer_document")
}

// ── Gym-Owner Lead (for hire-trainer contact flow) ──────────
model GymOwnerLead {
