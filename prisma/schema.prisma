generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  password        String
  name            String
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  roleId          String?
  ownedGym        Gym?            @relation("GymOwner")
  memberProfile   Member?
  refreshTokens   RefreshToken[]
  trainerProfile  Trainer?
  role            Rolemaster?     @relation(fields: [roleId], references: [Id])
  memberInquiries MemberInquiry[]

  @@index([email])
  @@index([roleId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model GymSubscriptionPlan {
  id            String   @id @default(uuid())
  name          String
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  durationDays  Int
  features      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  priceCurrency String   @default("INR")
  gyms          Gym[]

  @@index([isActive])
  @@index([priceCurrency])
}

model Gym {
  id                 String               @id @default(uuid())
  name               String
  address            String?              // Legacy field - use address1, address2 instead
  address1           String?              // Primary address line
  address2           String?              // Secondary address line
  city               String?
  state              String?
  zipcode            String?              // Only numbers allowed (validated at API level)
  phone              String?              // Legacy field - use phoneNo instead
  mobileNo           String?              // Only numbers allowed (validated at API level)
  phoneNo            String?              // Only numbers allowed (validated at API level)
  email              String?              // Email with validation at API level
  gstRegNo           String?              // GST Registration Number
  website            String?
  note               String?              // Terms and Conditions shown on receipts
  logo               String?              // Legacy field - use gymLogo instead
  gymLogo            String?              // Path to gym logo image
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  ownerId            String?              @unique
  subscriptionPlanId String?
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  dietPlans          DietPlan[]
  exercisePlans      ExercisePlan[]
  owner              User?                @relation("GymOwner", fields: [ownerId], references: [id])
  subscriptionPlan   GymSubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  members            Member[]
  trainers           Trainer[]
  expenseGroups      ExpenseGroupMaster[]
  designations       DesignationMaster[]
  bodyParts          BodyPartMaster[]
  workoutExercises   WorkoutExerciseMaster[]
  memberInquiries    MemberInquiry[]
  coursePackages     CoursePackage[]

  @@index([ownerId])
  @@index([city])
  @@index([state])
  @@index([zipcode])
  @@index([gstRegNo])
}

model Trainer {
  id             String                    @id @default(uuid())
  specialization String?
  experience     Int?
  phone          String?
  isActive       Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  createdBy      String?
  updatedBy      String?
  userId         String                    @unique
  gymId          String
  members        MemberTrainerAssignment[]
  ptMembers      PTMember[]
  gym            Gym                       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gymId])
}

model Member {
  id                  String                     @id @default(uuid())
  memberId            String?                    // Auto-generated member ID (e.g., 1413)
  phone               String?
  altContactNo        String?                    // Alternate contact number
  dateOfBirth         DateTime?
  gender              String?
  address             String?
  occupation          String?                    // Member's occupation
  maritalStatus       String?                    // Marital status
  bloodGroup          String?                    // Blood group
  anniversaryDate     DateTime?                  // Anniversary date
  emergencyContact    String?
  healthNotes         String?
  idProofType         String?                    // Type of ID proof (Aadhar, PAN, etc.)
  idProofDocument     String?                    // Path to uploaded ID document
  memberPhoto         String?                    // Path to member photo
  smsFacility         Boolean                    @default(true)  // SMS facility preference
  isActive            Boolean                    @default(true)  // For soft delete
  memberType          MemberType                 @default(REGULAR)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  createdBy           String?
  updatedBy           String?
  userId              String                     @unique
  gymId               String
  membershipStart     DateTime                   @default(now())
  membershipEnd       DateTime
  coursePackageId     String?                    // Reference to course package
  packageFees         Decimal?                   @db.Decimal(10, 2) // Original package fees
  maxDiscount         Decimal?                   @db.Decimal(10, 2) // Maximum allowed discount
  afterDiscount       Decimal?                   @db.Decimal(10, 2) // Amount after applying max discount
  extraDiscount       Decimal?                   @db.Decimal(10, 2) // Additional extra discount
  finalFees           Decimal?                   @db.Decimal(10, 2) // Final fees after all discounts
  membershipStatus    SubscriptionStatus         @default(ACTIVE)
  gym                 Gym                        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietAssignments     MemberDietAssignment[]
  exerciseAssignments MemberExerciseAssignment[]
  trainerAssignments  MemberTrainerAssignment[]
  ptMember            PTMember?
  memberDietPlans     MemberDietPlan[]
  balancePayments     MemberBalancePayment[]     // Balance payment records

  @@index([gymId])
  @@index([membershipStatus])
  @@index([memberType])
  @@index([memberId])
  @@index([isActive])
}

// Member Balance Payment - tracks partial payments toward final fees
model MemberBalancePayment {
  id              String    @id @default(uuid())
  receiptNo       String    // Auto-generated receipt number (e.g., RCP-001)
  memberId        String    // Reference to Member
  paymentDate     DateTime  @default(now())
  contactNo       String?   // Member contact (from member or override)
  paidFees        Decimal   @db.Decimal(10, 2) // Amount paid in this transaction
  payMode         String    // CASH, CARD, UPI, BANK_TRANSFER, CHEQUE, etc.
  nextPaymentDate DateTime? // Optional next payment reminder date
  notes           String?   // Optional notes/remarks
  isActive        Boolean   @default(true)
  gymId           String    // Reference to Gym for ownership
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  updatedBy       String?
  member          Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([gymId])
  @@index([receiptNo])
  @@index([paymentDate])
  @@map("memberbalancepayment")
}

model PTMember {
  id              String       @id @default(uuid())
  memberId        String       @unique
  trainerId       String
  packageName     String
  sessionsTotal   Int
  sessionsUsed    Int          @default(0)
  sessionDuration Int          @default(60)
  startDate       DateTime     @default(now())
  endDate         DateTime?
  goals           String?
  notes           String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String?
  updatedBy       String?
  gymId           String
  member          Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer         Trainer      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  supplements     Supplement[]

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
}

model Supplement {
  id          String    @id @default(uuid())
  ptMemberId  String
  name        String
  dosage      String?
  frequency   String?
  timing      String?
  notes       String?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  gymId       String
  ptMember    PTMember  @relation(fields: [ptMemberId], references: [id], onDelete: Cascade)

  @@index([ptMemberId])
  @@index([gymId])
}

model MemberDietPlan {
  id          String    @id @default(uuid())
  memberId    String
  planName    String
  description String?
  calories    Int?
  meals       Json
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  gymId       String
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([gymId])
}

model Inquiry {
  id          String        @id @default(uuid())
  name        String
  email       String?
  phone       String
  source      InquirySource @default(WALK_IN)
  interest    String?
  notes       String?
  status      InquiryStatus @default(NEW)
  followUpDate DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String?
  updatedBy   String?
  gymId       String

  @@index([gymId])
  @@index([status])
}

model MemberInquiry {
  id            String    @id @default(uuid())
  fullName      String
  contactNo     String
  inquiryDate   DateTime  @default(now())
  dob           DateTime?
  followUp      Boolean   @default(false)
  followUpDate  DateTime?
  gender        String?   // Male/Female/Other
  address       String?
  heardAbout    String?
  userId        String
  comments      String?
  memberPhoto   String?
  height        Decimal?  @db.Decimal(5, 2)
  weight        Decimal?  @db.Decimal(5, 2)
  referenceName String?
  gymId         String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?
  updatedBy     String?
  gym           Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberinquiry")
  @@index([gymId])
  @@index([userId])
  @@index([contactNo])
  @@index([inquiryDate])
  @@index([followUp])
  @@index([isActive])
}

model DietPlan {
  id          String                 @id @default(uuid())
  name        String
  description String?
  calories    Int?
  meals       Json
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  gymId       String
  gym         Gym                    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  assignments MemberDietAssignment[]

  @@index([gymId])
}

model ExercisePlan {
  id          String                     @id @default(uuid())
  name        String
  description String?
  type        String?
  exercises   Json
  isActive    Boolean                    @default(true)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  gymId       String
  gym         Gym                        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  assignments MemberExerciseAssignment[]

  @@index([gymId])
}

model MemberTrainerAssignment {
  id         String   @id @default(uuid())
  memberId   String
  trainerId  String
  assignedAt DateTime @default(now())
  isActive   Boolean  @default(true)
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer    Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([memberId, trainerId])
  @@index([memberId])
  @@index([trainerId])
}

model MemberDietAssignment {
  id         String    @id @default(uuid())
  memberId   String
  dietPlanId String
  assignedAt DateTime  @default(now())
  startDate  DateTime  @default(now())
  endDate    DateTime?
  isActive   Boolean   @default(true)
  dietPlan   DietPlan  @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  member     Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([dietPlanId])
}

model MemberExerciseAssignment {
  id             String       @id @default(uuid())
  memberId       String
  exercisePlanId String
  assignedAt     DateTime     @default(now())
  dayOfWeek      Int?
  startDate      DateTime     @default(now())
  endDate        DateTime?
  isActive       Boolean      @default(true)
  exercisePlan   ExercisePlan @relation(fields: [exercisePlanId], references: [id], onDelete: Cascade)
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([exercisePlanId])
}

model Rolemaster {
  Id       String @id @default(uuid()) @map("Id")
  rolename String @map("rolename")
  users    User[]

  @@map("Rolemaster")
}

model OccupationMaster {
  id             String   @id @default(uuid())
  occupationName String   @unique
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?

  @@map("occupationmaster")
  @@index([isActive])
  @@index([occupationName])
}

model EnquiryTypeMaster {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@map("enquirytypemaster")
  @@index([isActive])
  @@index([name])
}

model PaymentTypeMaster {
  id              String   @id @default(uuid())
  paymentTypeName String   @unique
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?

  @@map("paymenttypemaster")
  @@index([isActive])
  @@index([paymentTypeName])
}

model ExpenseGroupMaster {
  id               String   @id @default(uuid())
  expenseGroupName String
  gymId            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  gym              Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([expenseGroupName, gymId])
  @@map("expensegroupmaster")
  @@index([gymId])
  @@index([expenseGroupName])
}

model DesignationMaster {
  id              String   @id @default(uuid())
  designationName String
  gymId           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  gym             Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([designationName, gymId])
  @@map("designationmaster")
  @@index([gymId])
  @@index([designationName])
}

model BodyPartMaster {
  id           String                  @id @default(uuid())
  bodyPartName String
  description  String?
  isActive     Boolean                 @default(true)
  gymId        String
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  gym          Gym                     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  exercises    WorkoutExerciseMaster[]

  @@unique([bodyPartName, gymId])
  @@map("bodypartmaster")
  @@index([gymId])
  @@index([bodyPartName])
  @@index([isActive])
}

model WorkoutExerciseMaster {
  id           String          @id @default(uuid())
  exerciseName String
  shortCode    String?         @db.VarChar(20)
  description  String?
  isActive     Boolean         @default(true)
  gymId        String
  bodyPartId   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  gym          Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  bodyPart     BodyPartMaster? @relation(fields: [bodyPartId], references: [id], onDelete: SetNull)

  @@unique([exerciseName, gymId])
  @@map("workoutexercisemaster")
  @@index([gymId])
  @@index([exerciseName])
  @@index([shortCode])
  @@index([isActive])
  @@index([bodyPartId])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MemberType {
  REGULAR
  PT
}

enum InquirySource {
  WALK_IN
  PHONE
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  OTHER
}

enum InquiryStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
  FOLLOW_UP
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
}

model CoursePackage {
  id            String       @id @default(uuid())
  packageName   String
  description   String?
  fees          Decimal      @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  discountType  DiscountType @default(PERCENTAGE)
  isActive      Boolean      @default(true)
  gymId         String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     String?
  updatedBy     String?
  gym           Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([packageName, gymId])
  @@map("coursepackage")
  @@index([gymId])
  @@index([packageName])
  @@index([isActive])
}
